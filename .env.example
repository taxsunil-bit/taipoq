# Public CSV or JSON URL for Upcoming Exams page (optional)
#
# If not set, /upcoming-exams uses /data/upcoming-exams.json by default.
#
# If Google Sheet is not used, host exam data from public/data/upcoming-exams.json
#
# Option A — Google Sheet publish link (CSV):
#   File → Share → Publish to web → CSV
#
# Option B — Local/public JSON on TAIPOQ (served from public/data/):
# VITE_UPCOMING_EXAMS_DATA_URL=https://www.taipoq.com/data/upcoming-exams.json

# Set true only after verified vacancy cards pass manual QA.
VITE_SHOW_VERIFIED_VACANCIES=false
